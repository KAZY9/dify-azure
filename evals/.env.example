# evals/.env のテンプレート。 cp evals/.env.example evals/.env して実値を記入（.env はコミットしない）。

# --- Dify（公開したワークフローアプリの API） ---
# 例: https://40.115.193.114/v1  （末尾 /v1 まで）
DIFY_API_BASE=https://<DIFY_IP_OR_DOMAIN>/v1
# Dify アプリの「APIキー」（アプリ → API アクセス で発行）
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx
# 開始ノードのファイル入力変数名（フロー作成時に付けた名前）
DIFY_FILE_VAR=file
# 自己署名証明書のため TLS 検証を無効化（本番ドメイン+正規証明書なら true）
DIFY_VERIFY_SSL=false

# --- Azure OpenAI（LLM-as-judge 用。抽出フローとは別枠でも可） ---
AZURE_OPENAI_ENDPOINT=https://oai-dify-fgqgd2etkg4ok.openai.azure.com/
AZURE_OPENAI_API_KEY=<azure-openai-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Langfuse Cloud（観測・評価記録。未設定なら Langfuse 連携はスキップ） ---
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx

# --- 合否しきい値（CI 用。全体スコアがこれ未満で失敗） ---
PASS_THRESHOLD=0.8
