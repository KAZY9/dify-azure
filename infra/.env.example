# infra/.env のテンプレート。
#   cp infra/.env.example infra/.env  して実値を記入する。
#   infra/.env は .gitignore 済み（コミットしない）。
#
# 使い方（デプロイ前に環境変数を読み込む）:
#   set -a; source infra/.env; set +a
#   az deployment sub create -l japaneast -f infra/main.bicep -p infra/main.bicepparam

# SSH を許可する送信元 CIDR（自分のグローバル IP に絞る）。
# 現在の IP 確認: curl -s https://api.ipify.org
DIFY_SSH_CIDR=203.0.113.10/32

# SSH 公開鍵の内容（cat ~/.ssh/dify_azure.pub の出力をそのまま）。
DIFY_SSH_PUBKEY=ssh-ed25519 AAAA... dify-azure
